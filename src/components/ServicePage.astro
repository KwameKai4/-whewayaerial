---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Footer from './Footer.astro';
import ArrowIcon from './ArrowIcon.astro';
import mappedImage from '../assets/mapped-property.png';
import { sitePath } from '../utils/sitePath';

interface Step {
  title: string;
  copy: string;
}

interface RelatedService {
  href: string;
  label: string;
  copy: string;
}

interface Props {
  title: string;
  description: string;
  h1: string;
  intro: string;
  serviceName: string;
  serviceValue: string;
  suitableFor: string[];
  deliverables: string[];
  process: Step[];
  limitations: string[];
  guidePrice: string;
  priceNote: string;
  related: RelatedService[];
}

const {
  title,
  description,
  h1,
  intro,
  serviceName,
  serviceValue,
  suitableFor,
  deliverables,
  process,
  limitations,
  guidePrice,
  priceNote,
  related,
} = Astro.props;

const homeURL = new URL(sitePath('/'), Astro.site).href;
const pageURL = new URL(sitePath(Astro.url.pathname), Astro.site).href;
const enquiryURL = `${sitePath('/')}?service=${encodeURIComponent(serviceValue)}#contact`;
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: serviceName,
      description,
      url: pageURL,
      areaServed: { '@type': 'AdministrativeArea', name: 'Somerset' },
      provider: { '@type': 'Organization', name: 'WhewayDrones', url: homeURL },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: homeURL },
        { '@type': 'ListItem', position: 2, name: serviceName, item: pageURL },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <Header />
  <main id="top" class="service-page">
    <section class="service-page-hero topo-bg" aria-labelledby="service-title">
      <div class="service-page-intro">
        <nav class="breadcrumbs" aria-label="Breadcrumb"><a href={sitePath('/')}>Home</a><span aria-hidden="true">/</span><span>{serviceName}</span></nav>
        <h1 id="service-title">{h1}</h1>
        <p>{intro}</p>
        <div class="service-page-actions">
          <a class="button" href={enquiryURL}>Check your site <ArrowIcon /></a>
          <a class="text-link" href="#details">See what is included <ArrowIcon /></a>
        </div>
      </div>
      <div class="service-page-media" aria-hidden="true">
        <Image src={mappedImage} alt="" widths={[640, 960, 1400]} sizes="(max-width: 800px) 100vw, 46vw" format="webp" quality={82} loading="eager" fetchpriority="high" />
      </div>
    </section>

    <section class="service-detail section" id="details" aria-labelledby="fit-title">
      <div class="service-detail-heading">
        <p class="section-label">Where it fits</p>
        <h2 id="fit-title">Useful when the output has a clear job.</h2>
      </div>
      <div class="service-detail-columns">
        <article>
          <h3>Suitable for</h3>
          <ul>{suitableFor.map((item) => <li>{item}</li>)}</ul>
        </article>
        <article>
          <h3>Typical deliverables</h3>
          <ul>{deliverables.map((item) => <li>{item}</li>)}</ul>
        </article>
      </div>
    </section>

    <section class="service-method section topo-bg" aria-labelledby="method-title">
      <div>
        <p class="section-label">Method</p>
        <h2 id="method-title">Scoped before take-off.</h2>
      </div>
      <ol>
        {process.map((step, index) => (
          <li><span>0{index + 1}</span><div><h3>{step.title}</h3><p>{step.copy}</p></div></li>
        ))}
      </ol>
    </section>

    <section class="service-boundaries section" aria-labelledby="boundaries-title">
      <div>
        <p class="section-label">Important boundaries</p>
        <h2 id="boundaries-title">Clear about what the files mean.</h2>
      </div>
      <ul>{limitations.map((item) => <li>{item}</li>)}</ul>
    </section>

    <section class="service-price-band" aria-label="Guide price and enquiry">
      <div><span>Guide price</span><strong>{guidePrice}</strong><p>{priceNote}</p></div>
      <a class="button" href={enquiryURL}>Check feasibility and price <ArrowIcon /></a>
    </section>

    <section class="related-services section" aria-labelledby="related-title">
      <div><p class="section-label">Related services</p><h2 id="related-title">Choose the output you actually need.</h2></div>
      <div class="related-service-links">
        {related.map((item) => (
          <a href={sitePath(item.href)}><strong>{item.label}</strong><span>{item.copy}</span><ArrowIcon /></a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
