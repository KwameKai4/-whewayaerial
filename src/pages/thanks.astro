---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sitePath } from '../utils/sitePath';
---
<BaseLayout title="Enquiry sent | WhewayAerial" description="Your WhewayAerial enquiry has been sent." robots="noindex, follow">
  <main class="thanks-page topo-bg">
    <a class="wordmark" href={sitePath('/')}>Wheway<span>Aerial</span></a>
    <div>
      <p class="section-label">Enquiry received</p>
      <h1>Thanks. I’ll take a look.</h1>
      <p>Your project details have been sent. I’ll check the location, likely deliverables and any obvious flight constraints before replying.</p>
      <a class="button" href={sitePath('/')}>Back to WhewayAerial</a>
    </div>
  </main>
</BaseLayout>
