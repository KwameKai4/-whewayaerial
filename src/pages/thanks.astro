---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { sitePath } from '../utils/sitePath';
---
<BaseLayout title="Enquiry sent | WhewayDrones" description="Your WhewayDrones enquiry has been sent." robots="noindex, follow">
  <main class="thanks-page topo-bg">
    <a class="wordmark" href={sitePath('/')}>Wheway<span>Drones</span></a>
    <div>
      <p class="section-label">Enquiry received</p>
      <h1>Thanks. I’ll take a look.</h1>
      <p>Your project details have been sent. I’ll check the location, likely deliverables and any obvious flight constraints before replying.</p>
      <a class="button" href={sitePath('/')}>Back to WhewayDrones</a>
    </div>
  </main>
  <Footer />
</BaseLayout>
